#include "gps.h"
#include "main.h"

void RTC_SetFromTM(struct tm *t)
{
    RTC_TimeTypeDef sTime = {0};
    RTC_DateTypeDef sDate = {0};

    sTime.Hours   = t->tm_hour;
    sTime.Minutes = t->tm_min;
    sTime.Seconds = t->tm_sec;
    sTime.DayLightSaving = RTC_DAYLIGHTSAVING_NONE;
    sTime.StoreOperation = RTC_STOREOPERATION_RESET;

    HAL_RTC_SetTime(&hrtc, &sTime, RTC_FORMAT_BIN);

    sDate.WeekDay = RTC_WEEKDAY_MONDAY; // opcional
    sDate.Month   = t->tm_mon + 1;
    sDate.Date    = t->tm_mday;
    sDate.Year    = (t->tm_year + 1900) - 2000;

    HAL_RTC_SetDate(&hrtc, &sDate, RTC_FORMAT_BIN);
}

void RTC_GetToTM(struct tm *t)
{
    RTC_TimeTypeDef sTime;
    RTC_DateTypeDef sDate;

    HAL_RTC_GetTime(&hrtc, &sTime, RTC_FORMAT_BIN);
    HAL_RTC_GetDate(&hrtc, &sDate, RTC_FORMAT_BIN); // necesario!

    t->tm_hour = sTime.Hours;
    t->tm_min  = sTime.Minutes;
    t->tm_sec  = sTime.Seconds;

    t->tm_mday = sDate.Date;
    t->tm_mon  = sDate.Month - 1;
    t->tm_year = sDate.Year + 100; // desde 2000 → +100
}

extern "C" void setManualTime(int year, int month, int day,
                   int hour, int min, int sec)
{
    struct tm t = {0};

    t.tm_year = year - 1900;
    t.tm_mon  = month - 1;
    t.tm_mday = day;
    t.tm_hour = hour;
    t.tm_min  = min;
    t.tm_sec  = sec;

    RTC_SetFromTM(&t);

  //  printf("[RTC] Manual time set\n");
}


